APP_NAME=CLYX
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Local API: http://127.0.0.1:8001 — Production: https://api.clyx.agency (required for correct /storage/* links in JSON)
APP_URL=http://localhost:8000

# SPA origins (must match browser Origin exactly: scheme + host, no trailing slash). Used by CORS.
# Production: https://clyx.agency — if wrong, browser shows CORS errors; if API returns 500, fix DB/migrations first.
FRONTEND_URL=http://localhost:5174
LANDING_URL=http://localhost:5173
# Optional: e.g. https://www.clyx.agency if the site is also opened with www
# CORS_EXTRA_ORIGIN=

# Sanctum SPA hosts (comma-separated, no scheme). Needed if you use cookie/session API from the SPA.
# Production example: clyx.agency,www.clyx.agency
# SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:5174,127.0.0.1

# Behind cPanel / load balancer / Cloudflare — if URLs or HTTPS detection are wrong, try:
# TRUSTED_PROXIES=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local default is sqlite; production (cPanel): use mysql and credentials from "MySQL® Databases"
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=clyx_db
# DB_USERNAME=
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Task management emails (production cPanel — set password only on server, never commit)
# MAIL_MAILER=smtp
# MAIL_HOST=mail.clyx.agency
# MAIL_PORT=465
# MAIL_USERNAME=TaskMangement@clyx.agency
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=ssl
# MAIL_FROM_ADDRESS=TaskMangement@clyx.agency
# MAIL_FROM_NAME="CLYX Task Management"
# QUEUE_CONNECTION=database

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
